<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!--
        Exeris Spring Runtime — Root Reactor POM
        =========================================
        This is the top-level reactor. It orchestrates the build order and
        centralises version management via the BOM submodule.

        This project is NOT a Spring Boot starter.
        It is a host-runtime integration layer in which:
          - Spring provides application model, DI, and configuration ergonomics.
          - Exeris owns transport ingress, request lifecycle, backpressure,
            off-heap memory, provider discovery, and runtime telemetry.

        See docs/architecture/overview.md for the full architectural contract.
    -->

    <groupId>eu.exeris</groupId>
    <artifactId>exeris-spring-runtime-parent</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>Exeris Spring Runtime :: Parent</name>
    <description>Host-runtime integration layer enabling Spring applications to run on top of the Exeris execution model.</description>

    <modules>
        <module>exeris-spring-runtime-bom</module>
        <module>exeris-spring-runtime-build-config</module>
        <module>exeris-spring-boot-autoconfigure</module>
        <module>exeris-spring-runtime-web</module>
        <module>exeris-spring-runtime-tx</module>
        <module>exeris-spring-runtime-data</module>
        <module>exeris-spring-runtime-actuator</module>
    </modules>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Java version — aligned with exeris-kernel -->
        <maven.compiler.source>26</maven.compiler.source>
        <maven.compiler.target>26</maven.compiler.target>
        <maven.compiler.release>26</maven.compiler.release>

        <!-- Dependency versions -->
        <exeris.kernel.version>0.6.0-SNAPSHOT</exeris.kernel.version>
        <spring.boot.version>3.5.13</spring.boot.version>
        <spring.framework.version>6.2.4</spring.framework.version>

        <!-- Build tooling -->
        <maven.compiler.plugin.version>3.14.1</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.2.5</maven.surefire.plugin.version>
        <maven.failsafe.plugin.version>3.2.5</maven.failsafe.plugin.version>

            <!-- Test tooling -->
            <archunit.version>1.3.0</archunit.version>
        <!-- Jackson annotations version required by tools.jackson.databind:3.1.1 -->
        <jackson.annotations.version>2.21</jackson.annotations.version>

        <!-- Test JVM args — aligned with kernel conventions.
             enable-preview is required because exeris-kernel-core is compiled with
             Java 26 preview features (class file minor version 65535). Without this
             flag the JVM refuses to load those classes at test runtime. -->
        <test.jvm.args>--enable-preview -XX:+UnlockExperimentalVMOptions -XX:+UseZGC</test.jvm.args>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Exeris Kernel BOM -->
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-kernel-bom</artifactId>
                <version>${exeris.kernel.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Spring Boot BOM — governs all Spring dependency versions.
                 IMPORTANT: spring-boot-starter-web and spring-boot-starter-webflux
                 are NEVER imported in any module. Tomcat, Jetty, Undertow, and Netty
                 are excluded from the runtime classpath.
                 Exeris owns the transport layer. -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring.boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Internal module versions -->
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-boot-autoconfigure</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-runtime-web</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-runtime-tx</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-runtime-data</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-runtime-actuator</artifactId>
                <version>${project.version}</version>
            </dependency>

                <!-- Architecture guards -->
                <dependency>
                    <groupId>com.tngtech.archunit</groupId>
                    <artifactId>archunit-junit5</artifactId>
                    <version>${archunit.version}</version>
                    <scope>test</scope>
                </dependency>

            <!--
                Jackson annotations version override.
                tools.jackson.core:jackson-databind:3.1.1 (Jackson 3.x, used by exeris-kernel-community)
                requires jackson-annotations:2.21 since that is where JsonSerializeAs was introduced
                (see Jackson BOM 3.1.1: jackson.version.annotations=2.21).
                Spring Boot BOM 3.5.13 manages jackson-annotations to 2.18.2, which predates
                JsonSerializeAs. This direct dependency management entry takes Maven precedence
                over the BOM-sourced 2.18.2.
                jackson-annotations is backward-compatible so upgrading from 2.18.2 to 2.21
                does not affect Spring Boot components.
            -->
            <dependency>
                <groupId>com.fasterxml.jackson.core</groupId>
                <artifactId>jackson-annotations</artifactId>
                <version>${jackson.annotations.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>${maven.compiler.plugin.version}</version>
                    <configuration>
                        <release>${maven.compiler.release}</release>
                        <compilerArgs>
                            <arg>--enable-preview</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>${maven.surefire.plugin.version}</version>
                    <configuration>
                        <argLine>${test.jvm.args}</argLine>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-failsafe-plugin</artifactId>
                    <version>${maven.failsafe.plugin.version}</version>
                    <configuration>
                        <argLine>${test.jvm.args}</argLine>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

</project>
