<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!--
        Exeris Spring Runtime — Root Reactor POM
        =========================================
        This is the top-level reactor. It orchestrates the build order and
        centralises version management via the BOM submodule.

        This project is NOT a Spring Boot starter.
        It is a host-runtime integration layer in which:
          - Spring provides application model, DI, and configuration ergonomics.
          - Exeris owns transport ingress, request lifecycle, backpressure,
            off-heap memory, provider discovery, and runtime telemetry.

        See docs/architecture/overview.md for the full architectural contract.
    -->

    <groupId>eu.exeris</groupId>
    <artifactId>exeris-spring-runtime-parent</artifactId>
    <version>0.5.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>Exeris Spring Runtime :: Parent</name>
    <description>Host-runtime integration layer enabling Spring applications to run on top of the Exeris execution model.</description>

    <modules>
        <module>exeris-spring-runtime-bom</module>
        <module>exeris-spring-runtime-build-config</module>
        <module>exeris-spring-boot-autoconfigure</module>
        <module>exeris-spring-runtime-web</module>
        <module>exeris-spring-runtime-tx</module>
        <module>exeris-spring-runtime-data</module>
        <module>exeris-spring-runtime-actuator</module>
        <module>exeris-spring-runtime-events</module>
        <module>exeris-spring-runtime-flow</module>
        <module>exeris-spring-runtime-graph</module>
    </modules>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Java version — aligned with exeris-kernel -->
        <maven.compiler.source>26</maven.compiler.source>
        <maven.compiler.target>26</maven.compiler.target>
        <maven.compiler.release>26</maven.compiler.release>

        <!-- Dependency versions -->
        <!-- Pinned to the released 0.8.1 (clean, not -SNAPSHOT): the datasource SPI-unwrap
             bridge requires kernel >= 0.8.1, and 0.8.1-SNAPSHOT was never published to
             GitHub Packages (the kernel went straight to the 0.8.1 release), so a -SNAPSHOT
             reference fails to resolve (401/absent) in CI. -->
        <exeris.kernel.version>0.8.1</exeris.kernel.version>
        <!-- Spring Boot 3.5.14 ships fixes for SNYK-JAVA-ORGSPRINGFRAMEWORKBOOT-16191649
             (CWE-338 Weak PRNG, CVE-2026-40975), -16198880 (CWE-377 Insecure Temp File,
             CVE-2026-40973), -16201011 (CWE-59 Symlink Attack, CVE-2026-40977),
             -16191022 + -16200231 (CWE-297 Cert Hostname Mismatch, CVE-2026-40974 / -40971).
             The same bump pulls spring-web through the BOM to a version that addresses
             SNYK-JAVA-ORGSPRINGFRAMEWORK-16109615 (CWE-459 Incomplete Cleanup, CVE-2026-22740). -->
        <spring.boot.version>3.5.14</spring.boot.version>
        <spring.framework.version>6.2.4</spring.framework.version>

        <!-- Build tooling -->
        <maven.compiler.plugin.version>3.14.1</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.2.5</maven.surefire.plugin.version>
        <maven.failsafe.plugin.version>3.2.5</maven.failsafe.plugin.version>

        <!-- Coverage quality gate (opt-in via -Pcoverage). 0.8.15 is the first
             JaCoCo with JDK 26 class-file support (major version 70) — see the
             budgetHQ backend parent pom, which pins it for the same reason. -->
        <jacoco.maven.plugin.version>0.8.15</jacoco.maven.plugin.version>
        <!-- Per-module LINE floor enforced by the -Pcoverage `check` goal. This is
             a RATCHET, not the target: each module overrides it in its own
             <properties> at-or-just-below current coverage so regressions fail
             while the existing baseline passes. The 1.0 GA destination is ~0.85
             per module; floors ratchet up toward it as modules approach GA.
             Modules without their own tests produce no jacoco.exec — `check`
             then no-ops silently (no skip flag needed). -->
        <jacoco.line.minimum>0.00</jacoco.line.minimum>
        <!-- Set by jacoco:prepare-agent; consumed late-bound (@{...}) by the
             surefire/failsafe argLine below. A direct ${...} reference would be
             interpolated before prepare-agent runs, so the agent would never
             attach (see budgetHQ backend pom §argLine note). -->
        <coverage.argLine/>

        <!-- Test tooling. ArchUnit 1.4.2 bundles an ASM that reads JDK 26
             class files (major version 70); 1.3.0's older ASM throws
             "Unsupported class file major version 70" and silently skips
             those classes — which would let the Wall/boundary guards pass
             without actually inspecting Java 26 bytecode. Aligned with the
             exeris-kernel BOM (archunit 1.4.2). -->
        <archunit.version>1.4.2</archunit.version>
        <!-- Jackson annotations version required by tools.jackson.databind:3.1.1 -->
        <jackson.annotations.version>2.21</jackson.annotations.version>

        <!-- Test JVM args — aligned with kernel conventions.
             enable-preview is required because exeris-kernel-core is compiled with
             Java 26 preview features (class file minor version 65535). Without this
             flag the JVM refuses to load those classes at test runtime. -->
        <test.jvm.args>--enable-preview -XX:+UnlockExperimentalVMOptions -XX:+UseZGC</test.jvm.args>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Exeris Kernel BOM -->
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-kernel-bom</artifactId>
                <version>${exeris.kernel.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Spring Boot BOM — governs all Spring dependency versions.
                 IMPORTANT: spring-boot-starter-web and spring-boot-starter-webflux
                 are NEVER imported in any module. Tomcat, Jetty, Undertow, and Netty
                 are excluded from the runtime classpath.
                 Exeris owns the transport layer. -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring.boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Internal module versions -->
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-boot-autoconfigure</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-runtime-web</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-runtime-tx</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-runtime-data</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>eu.exeris</groupId>
                <artifactId>exeris-spring-runtime-actuator</artifactId>
                <version>${project.version}</version>
            </dependency>

                <!-- Architecture guards -->
                <dependency>
                    <groupId>com.tngtech.archunit</groupId>
                    <artifactId>archunit-junit5</artifactId>
                    <version>${archunit.version}</version>
                    <scope>test</scope>
                </dependency>

            <!--
                Jackson annotations version override.
                tools.jackson.core:jackson-databind:3.1.1 (Jackson 3.x, used by exeris-kernel-community)
                requires jackson-annotations:2.21 since that is where JsonSerializeAs was introduced
                (see Jackson BOM 3.1.1: jackson.version.annotations=2.21).
                Spring Boot BOM 3.5.13 manages jackson-annotations to 2.18.2, which predates
                JsonSerializeAs. This direct dependency management entry takes Maven precedence
                over the BOM-sourced 2.18.2.
                jackson-annotations is backward-compatible so upgrading from 2.18.2 to 2.21
                does not affect Spring Boot components.
            -->
            <dependency>
                <groupId>com.fasterxml.jackson.core</groupId>
                <artifactId>jackson-annotations</artifactId>
                <version>${jackson.annotations.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <repositories>
        <repository>
            <id>github-exeris-kernel</id>
            <url>https://maven.pkg.github.com/exeris-systems/exeris-kernel</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
        <repository>
            <id>github-exeris-spring-runtime</id>
            <url>https://maven.pkg.github.com/exeris-systems/exeris-spring-runtime</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
    </repositories>

    <distributionManagement>
        <repository>
            <id>github-exeris-runtime-releases</id>
            <url>https://maven.pkg.github.com/exeris-systems/exeris-spring-runtime</url>
        </repository>
        <snapshotRepository>
            <id>github-exeris-runtime-snapshots</id>
            <url>https://maven.pkg.github.com/exeris-systems/exeris-spring-runtime</url>
        </snapshotRepository>
    </distributionManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>${maven.compiler.plugin.version}</version>
                    <configuration>
                        <release>${maven.compiler.release}</release>
                        <compilerArgs>
                            <arg>--enable-preview</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>${maven.surefire.plugin.version}</version>
                    <configuration>
                        <argLine>@{coverage.argLine} ${test.jvm.args}</argLine>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-failsafe-plugin</artifactId>
                    <version>${maven.failsafe.plugin.version}</version>
                    <configuration>
                        <argLine>@{coverage.argLine} ${test.jvm.args}</argLine>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

    <profiles>
        <!-- Coverage quality gate. Opt-in (CI activates it explicitly, e.g.
             `mvn -Pcoverage verify`) so the default build stays agent-free:
             no per-class instrumentation overhead on the hot-path-adjacent
             integration tests, and the agent never perturbs timing-sensitive
             wire-level tests. Mirrors the exeris-kernel coverage profile. -->
        <profile>
            <id>coverage</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.jacoco</groupId>
                        <artifactId>jacoco-maven-plugin</artifactId>
                        <version>${jacoco.maven.plugin.version}</version>
                        <executions>
                            <execution>
                                <id>jacoco-prepare-agent</id>
                                <goals>
                                    <goal>prepare-agent</goal>
                                </goals>
                                <configuration>
                                    <propertyName>coverage.argLine</propertyName>
                                </configuration>
                            </execution>
                            <execution>
                                <id>jacoco-report</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>report</goal>
                                </goals>
                                <configuration>
                                    <formats>
                                        <format>XML</format>
                                        <format>HTML</format>
                                    </formats>
                                </configuration>
                            </execution>
                            <execution>
                                <id>jacoco-check</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>check</goal>
                                </goals>
                                <configuration>
                                    <haltOnFailure>true</haltOnFailure>
                                    <rules>
                                        <rule>
                                            <element>BUNDLE</element>
                                            <limits>
                                                <limit>
                                                    <counter>LINE</counter>
                                                    <value>COVEREDRATIO</value>
                                                    <minimum>${jacoco.line.minimum}</minimum>
                                                </limit>
                                            </limits>
                                        </rule>
                                    </rules>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

</project>
